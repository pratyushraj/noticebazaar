# ============================================
# Creator Armour — Environment Variables
# ============================================
# Copy this file to .env and fill in your values.
# NEVER commit .env to version control.

# --- Required ---
VITE_SUPABASE_URL=https://your-project.supabase.co
VITE_SUPABASE_ANON_KEY=your-supabase-anon-key

# --- API ---
VITE_API_URL=https://api.creatorarmour.com
VITE_APP_URL=https://creatorarmour.com

# --- Razorpay ---
VITE_RAZORPAY_KEY_ID=rzp_live_xxxxx

# --- Push Notifications ---
VITE_VAPID_PUBLIC_KEY=your-vapid-public-key
VITE_PUSH_API_BASE_URL=https://api.creatorarmour.com

# --- Sentry (optional) ---
VITE_SENTRY_DSN=

# --- CometChat (optional) ---
VITE_COMETCHAT_APP_ID=
VITE_COMETCHAT_AUTH_KEY=
VITE_COMETCHAT_REGION=

# --- AI / LLM ---
# Providers: huggingface, groq, together, gemini, nvidia
VITE_LLM_PROVIDER=nvidia
# Models: meta/llama-3.1-8b-instruct, meta/llama-3.1-405b-instruct, etc.
VITE_LLM_MODEL=meta/llama-3.1-8b-instruct
VITE_LLM_API_KEY=

# --- Bot / Service account ---
# Secret API key for OpenClaw or other trusted backend bot access.
OPENCLAW_API_KEY=your-openclaw-api-key

# --- Meta Pixel (optional) ---
VITE_META_PIXEL_ID=

# --- Supabase Storage Buckets ---
VITE_CLIENT_DOCUMENTS_BUCKET=client-documents
VITE_CREATOR_ASSETS_BUCKET=creator-assets
VITE_COPYRIGHT_SCREENSHOTS_BUCKET=copyright-screenshots
VITE_MARKETING_ASSETS_BUCKET=marketing-assets

# --- Misc ---
VITE_DEMO_MODE=false
VITE_USE_SUPABASE_PROXY=false
